---
layout: layouts/base.njk
title: Features & Reviews
---

<div class="container">
    <section class="hero">
      <h1>Tweg Movie Reviews</h1>
      <p>A home for my bullsh*t rambling thoughts about random movies</p>
      <div class="hero-actions">
        <a
          href="https://letterboxd.com/tweg5/"
          class="btn-primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          Letterboxd
        </a>
        <a href="{{ '/about/' | url }}" class="btn-secondary">About</a>
      </div>
    </section>

    <h2 class="section-title" id="latest-reviews">Latest Reviews</h2>
    
    <section class="reviews-list">
      {% if collections.reviews and collections.reviews.length %}
        <div class="reviews-grid">
          {% for review in collections.reviews %}
          <article class="review-card">
            <a href="{{ review.url | url }}">
                <h3 class="card-title">{{ review.data.title }}</h3>
                <div class="card-meta">
                  {% if review.data.rating %}
                  <span class="card-rating">
                    {% for i in range(0, review.data.rating) %}★{% endfor %}
                  </span>
                  {% endif %}
                  {% if review.data.year %}
                  <span class="card-year">{{ review.data.year }}</span>
                  {% endif %}
                  {% if review.data.director %}
                  <span class="card-director">Dir. {{ review.data.director }}</span>
                  {% endif %}
                </div>
                {% if review.data.tagline %}
                <p class="card-tagline">{{ review.data.tagline }}</p>
                {% elif review.templateContent %}
                <p class="card-tagline">{{ review.templateContent | excerpt }}</p>
                {% endif %}
            </a>
          </article>
          {% endfor %}
        </div>
      {% else %}
        <p class="no-reviews">The projector is warming up. Check back soon for reviews.</p>
      {% endif %}
    </section>
</div>
