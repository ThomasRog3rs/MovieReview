---
layout: layouts/base.njk
---

<article class="review-article container">
  <header class="review-header">
    <h1 class="review-title">{{ title }}</h1>

    <div class="review-meta-bar">
      {% if director %}
      <span class="review-meta-item">Dir. <strong>{{ director }}</strong></span>
      {% endif %}

      {% if year %}
      <span class="review-meta-item">{{ year }}</span>
      {% endif %}
      
      <span class="review-meta-item">
        <time datetime="{{ page.date | htmlDateString }}">
          {{ page.date | readableDate }}
        </time>
      </span>

      {% if rating %}
      <span class="review-meta-item review-rating-display" aria-label="Rating: {{ rating }} out of 5">
        {% for i in range(0, rating) %}★{% endfor %}
      </span>
      {% endif %}
    </div>

    {% if tagline %}
    <p class="review-tagline">{{ tagline }}</p>
    {% endif %}
  </header>

  <div class="review-body">
    {{ content | safe }}
  </div>

  <footer class="review-footer">
    <a href="{{ '/' | url }}" class="back-link">&larr; Back to Reviews</a>
    
    {% if letterboxdReviewUrl %}
    <a href="{{ letterboxdReviewUrl }}" target="_blank" rel="noopener noreferrer" class="btn-secondary">
        Like on Letterboxd
    </a>
    {% endif %}
  </footer>
</article>
