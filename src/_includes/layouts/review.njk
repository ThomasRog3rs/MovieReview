---
layout: layouts/base.njk
---

<article class="review">
  <header class="review-header">
    <h1 class="review-title">{{ title }}</h1>

    <div class="review-meta">
      {% if rating %}
      <span class="review-rating" aria-label="Rating: {{ rating }} out of 5">
        {% for i in range(0, rating) %}⭐{% endfor %}
        <span class="rating-text">{{ rating }}/5</span>
      </span>
      {% endif %}

      {% if director %}
      <span class="review-director">Directed by <strong>{{ director }}</strong></span>
      {% endif %}

      {% if year %}
      <span class="review-year">{{ year }}</span>
      {% endif %}

      <time class="review-date" datetime="{{ page.date | htmlDateString }}">
        {{ page.date | readableDate }}
      </time>
    </div>

    {% if tagline %}
    <p class="review-tagline"><em>{{ tagline }}</em></p>
    {% endif %}
  </header>

  <div class="review-body">
    {{ content | safe }}
  </div>

  {% if letterboxdReviewUrl %}
  <section class="review-letterboxd" aria-label="Letterboxd review link">
    <p class="review-letterboxd-text">If you enjoyed this review, like it on Letterboxd.</p>
    <a
      href="{{ letterboxdReviewUrl }}"
      class="letterboxd-link letterboxd-link-cta review-letterboxd-link"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Like this review on Letterboxd"
    >
      <span class="letterboxd-icon" aria-hidden="true">
        <svg viewBox="0 0 64 24" role="img" focusable="false">
          <circle cx="12" cy="12" r="8" fill="#40bc67"></circle>
          <circle cx="24" cy="12" r="8" fill="#ff8000"></circle>
          <circle cx="36" cy="12" r="8" fill="#00a7e1"></circle>
        </svg>
      </span>
      <span>Like on Letterboxd</span>
    </a>
  </section>
  {% endif %}

  <footer class="review-footer">
    <a href="{{ '/' | url }}" class="back-link">&larr; All Reviews</a>
  </footer>
</article>
