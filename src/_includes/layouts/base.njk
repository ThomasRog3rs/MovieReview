<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% if title %}{{ title }} | {% endif %}Tweg Movie Reviews</title>
    <link rel="stylesheet" href="{{ '/css/style.css' | url }}" />
  </head>
  <body{% if page.url == '/' %} class="home-page"{% endif %}>
    <header class="site-header" id="site-header">
      <div class="container">
        <a href="{{ '/' | url }}" class="site-title" aria-label="Tweg Movie Reviews home">
          Tweg Movie Reviews
        </a>
        <nav class="site-nav">
          <a href="{{ '/' | url }}#latest-reviews">Reviews</a>
          <a href="{{ '/about/' | url }}">About</a>
        </nav>
      </div>
    </header>

    <main>
      {{ content | safe }}
    </main>

    {% if page.url == '/' %}
    <script>
      const header = document.querySelector('#site-header');
      const reviewsHeading = document.querySelector('#latest-reviews');

      if (header && reviewsHeading) {
        const updateHeader = () => {
          header.classList.toggle(
            'is-visible',
            reviewsHeading.getBoundingClientRect().top <= header.offsetHeight
          );
        };

        updateHeader();
        window.addEventListener('scroll', updateHeader, { passive: true });
      }
    </script>
    {% endif %}

    <footer class="site-footer">
      <div class="container">
        <nav class="footer-nav">
            <a href="{{ '/' | url }}">Home</a>
            <a href="{{ '/about/' | url }}">About</a>
            <a href="https://letterboxd.com/tweg5/" target="_blank" rel="noopener">Letterboxd</a>
        </nav>
        <p class="footer-copy">Tweg Movie Reviews &copy; {% currentYear %} &mdash; Written after midnight.</p>
      </div>
    </footer>
  </body>
</html>
