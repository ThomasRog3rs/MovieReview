<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% if title %}{{ title }} | {% endif %}Movie Reviews</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="site-title">🎬 Movie Reviews</a>
        <nav>
          <a href="/">Home</a>
          <a href="/about/">About</a>
        </nav>
      </div>
    </header>

    <main class="container">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>Movie Reviews &copy; {{ page.date.getFullYear() }}</p>
      </div>
    </footer>
  </body>
</html>
